VITE_APP_ID=b2c-pmes
# Enable Email/Password in Firebase Console → Authentication → Sign-in method (member accounts + PMES resume).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Nest API base (TTS, member sync to Postgres, etc.). No Gemini key in the browser.
# Member sync uses Firebase ID tokens; backend must have Firebase Admin service account vars to verify tokens in production.
VITE_API_BASE_URL=http://localhost:3000
