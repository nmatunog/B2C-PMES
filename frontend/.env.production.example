# Build-time vars for production (e.g. `npm run build`).
# Set VITE_API_BASE_URL to your deployed Nest API origin (https, no trailing slash).
# Local dev keeps frontend/.env or .env.local with http://localhost:3000

VITE_APP_ID=b2c-pmes
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

VITE_API_BASE_URL=https://api.your-domain.com
