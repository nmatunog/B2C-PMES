#!/bin/sh
# Auto-push after each successful commit when core.hooksPath points here.
# Enable once: bash scripts/setup-git-hooks.sh
# Disable: git config --unset core.hooksPath

git_dir=$(git rev-parse --git-dir 2>/dev/null) || exit 0

# Avoid pushing mid-rebase/cherry-pick (would be wrong or fail).
[ -d "$git_dir/rebase-merge" ] && exit 0
[ -d "$git_dir/rebase-apply" ] && exit 0
[ -f "$git_dir/CHERRY_PICK_HEAD" ] && exit 0

branch=$(git symbolic-ref -q --short HEAD) || exit 0

# Default 'origin' — after scripts/github/switch-origin-to-dev.sh, origin is the dev repo.
remote="${GIT_AUTOPUSH_REMOTE:-origin}"

if git rev-parse '@{u}' >/dev/null 2>&1; then
  git push "$remote" || echo "post-commit: git push $remote failed (offline or remote rejected)." >&2
else
  git push -u "$remote" "$branch" || echo "post-commit: git push -u $remote failed." >&2
fi

exit 0
