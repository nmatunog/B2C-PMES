# Copy values into your hosting provider’s environment (Railway, Render, Fly, VPS, etc.).
# Do NOT replace backend/.env on your laptop — keep localhost there for daily dev.
#
# Neon (https://console.neon.tech):
# - DATABASE_URL = “Pooled connection” / pooler host (what the API uses under load).
# - DIRECT_URL   = “Direct connection” or non-pooler URL — Prisma needs this for `migrate deploy`.
# Both must point at the same Neon database; include ?sslmode=require if Neon shows it.

NODE_ENV=production
PORT=3000

DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# Generate a new secret for production (do not reuse dev).
ADMIN_JWT_SECRET=

# Firebase Admin — required for member sync / ID token verification in production.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: server-to-server member sync; browsers use Firebase Bearer tokens.
# MEMBER_SYNC_SECRET=

# After first deploy, from a shell with these env vars loaded:
#   cd backend && npx prisma migrate deploy
#   cd backend && npm run create-superuser -- admin@yourdomain.com 'SecurePassword'

AI_PROVIDER=noop
GEMINI_API_KEY=
