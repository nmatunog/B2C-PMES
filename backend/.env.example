NODE_ENV=development

# --- Local dev (Docker Postgres) — copy to .env and use for day-to-day coding; does not touch Neon. ---
# Start DB:  cd backend && npm run db:up
# Schema:    npx prisma migrate deploy   (or prisma migrate dev when you add migrations)
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/b2c_pmes
# For local Postgres, same connection string as DATABASE_URL (not pooled).
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/b2c_pmes

# --- Production (Neon) — set only on the host / CI, never in your laptop .env for normal dev. ---
# DATABASE_URL = Neon "pooled" connection string (for the running API).
# DIRECT_URL   = Neon "direct" or non-pooled URL (required by Prisma for migrations).
# prisma migrate deploy
PORT=3000

# Staff JWT (superuser + admins) — min 32 chars.
ADMIN_JWT_SECRET=change-me-to-a-secret-at-least-32-chars-long

# Optional: require X-Member-Sync-Secret on POST /auth/sync-member (Firebase → Postgres bridge). Use a long random string in production.
# Browsers use Authorization: Bearer <Firebase ID token> instead — set the three vars below (Firebase Console → Project settings → Service accounts).
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# MEMBER_SYNC_SECRET=
# Bootstrap: after migrate, run once:
#   cd backend && npm run create-superuser -- you@example.com 'YourSecurePassword'
# Only one superuser is allowed; further staff are ADMIN accounts created by the superuser (API + UI).

# AI TTS: noop | gemini | openai | grok (xAI). Keys only for the active provider.
AI_PROVIDER=noop
GEMINI_API_KEY=
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts

# Landing Ka-uban chat (text, marketing page): noop | gemini. Uses GEMINI_API_KEY when gemini.
LANDING_CHAT_PROVIDER=noop
# GEMINI_CHAT_MODEL=gemini-2.0-flash

OPENAI_API_KEY=
# OPENAI_TTS_MODEL=tts-1

# Grok / xAI TTS (https://api.x.ai/v1/tts)
XAI_API_KEY=
