generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/** Back-office staff: one bootstrap superuser (CLI), additional admins created only by superuser. */
model StaffUser {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         StaffRole
  createdAt    DateTime  @default(now())
  createdById  String?
  createdBy    StaffUser?  @relation("StaffCreatedBy", fields: [createdById], references: [id])
  createdStaff StaffUser[] @relation("StaffCreatedBy")
}

enum StaffRole {
  SUPERUSER
  ADMIN
}

model Participant {
  id            String         @id @default(uuid())
  fullName      String
  email         String         @unique
  phone         String
  dob           String
  gender        String
  createdAt     DateTime       @default(now())
  pmesRecords   PmesRecord[]
  loiSubmission LoiSubmission?
}

model PmesRecord {
  id            String      @id @default(uuid())
  score         Int
  passed        Boolean
  timestamp     DateTime    @default(now())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id])
}

model LoiSubmission {
  id             String      @id @default(uuid())
  address        String
  occupation     String
  employer       String
  initialCapital Float
  submittedAt    DateTime    @default(now())
  participantId  String      @unique
  participant    Participant @relation(fields: [participantId], references: [id])
}
